#!/bin/bash
set -euxo pipefail

apt-get update
apt-get install -y git python3 python3-venv python3-pip nginx certbot python3-certbot-nginx

cd /home/ubuntu
if [ ! -d ai-agents-basic ]; then
  git clone "${repo_url}" ai-agents-basic
fi

cd /home/ubuntu/ai-agents-basic
git fetch --all
git checkout "${repo_branch}"
git pull --ff-only origin "${repo_branch}" || true

# Ensure ubuntu can manage repo files later (e.g., uploading .env via scp).
chown -R ubuntu:ubuntu /home/ubuntu/ai-agents-basic

python3 -m venv .venv
source .venv/bin/activate
pip install --upgrade pip
pip install -r tutorial-api/requirements.txt
pip install -r tutorial-api/requirements-labs.txt
pip install gunicorn

cat >/etc/systemd/system/tutorial-api.service <<'EOF'
[Unit]
Description=Tutorial API Flask service
After=network.target

[Service]
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/ai-agents-basic/tutorial-api
EnvironmentFile=/home/ubuntu/ai-agents-basic/.env
ExecStart=/home/ubuntu/ai-agents-basic/.venv/bin/gunicorn --workers 2 --bind 127.0.0.1:5050 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

cat >/etc/nginx/sites-available/tutorial-api <<'EOF'
server {
  listen 80;
  server_name ${api_domain != "" ? api_domain : "_"};

  location /.well-known/acme-challenge/ {
    root /var/www/html;
  }

    location / {
        proxy_pass http://127.0.0.1:5050;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto http;
    }
}
EOF

rm -f /etc/nginx/sites-enabled/default
ln -sf /etc/nginx/sites-available/tutorial-api /etc/nginx/sites-enabled/tutorial-api

# Ensure env file path exists on first boot; real values can be uploaded later.
touch /home/ubuntu/ai-agents-basic/.env
chown ubuntu:ubuntu /home/ubuntu/ai-agents-basic/.env

systemctl daemon-reload
systemctl enable tutorial-api
systemctl restart tutorial-api
systemctl enable nginx
systemctl restart nginx

# If domain and email are provided, request a trusted cert and configure HTTPS redirect.
if [ -n "${api_domain}" ] && [ -n "${letsencrypt_email}" ]; then
  TOKEN=$(curl -X PUT "http://169.254.169.254/latest/api/token" -H "X-aws-ec2-metadata-token-ttl-seconds: 21600" || true)
  INSTANCE_PUBLIC_IP=$(curl -H "X-aws-ec2-metadata-token: $TOKEN" http://169.254.169.254/latest/meta-data/public-ipv4 || true)
  DOMAIN_IP=$(dig +short A ${api_domain} | tail -n1 || true)

  if [ -n "$INSTANCE_PUBLIC_IP" ] && [ "$INSTANCE_PUBLIC_IP" = "$DOMAIN_IP" ]; then
    certbot --nginx \
      --non-interactive \
      --agree-tos \
      --email "${letsencrypt_email}" \
      --domains "${api_domain}" \
      --redirect \
      --keep-until-expiring
    systemctl reload nginx
  else
    echo "Skipping Let's Encrypt issuance: ${api_domain} does not resolve to this EC2 public IP yet."
  fi
fi
