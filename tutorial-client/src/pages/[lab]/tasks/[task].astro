---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getLocalLabs } from "../../../lib/local-index";

export function getStaticPaths() {
  return getLocalLabs().flatMap((lab) =>
    lab.tasks.map((task) => ({
      params: {
        lab: lab.slug,
        task: String(task.id)
      }
    }))
  );
}

const { lab, task } = Astro.params;
const apiBase = (import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:5050").replace(/\/$/, "");
---

<BaseLayout
  title={`Task ${task} in ${lab}`}
  subtitle="Task view exposes one or more REST calls: get task details, get completion status, and run the script."
>
  <section class="card grid">
    <p style="margin:0; display:flex; gap:.55rem; flex-wrap:wrap;">
      <a class="link-button secondary" href={`/${lab}/`}>Back to lab</a>
      <button id="check-status" class="secondary">Check marker status</button>
      <button id="run-task">Run this task</button>
    </p>

    <div class="chips">
      <span class="chip mono">{lab}</span>
      <span class="chip mono">task-{task}</span>
    </div>

    <article class="card">
      <h2 style="margin-top:0;">Task source (from API)</h2>
      <p class="muted" id="task-meta">Loading task metadata...</p>
      <pre id="task-source" class="mono">Loading source...</pre>
    </article>

    <article class="card">
      <h2 style="margin-top:0;">Task operation output</h2>
      <pre id="task-output" class="mono">Use a button above to call the REST API.</pre>
    </article>
  </section>

  <script define:vars={{ lab, task, apiBase }}>
    const sourceEl = document.getElementById("task-source");
    const outputEl = document.getElementById("task-output");
    const metaEl = document.getElementById("task-meta");
    const checkBtn = document.getElementById("check-status");
    const runBtn = document.getElementById("run-task");

    async function loadTaskDetails() {
      try {
        const response = await fetch(`${apiBase}/api/labs/${lab}/tasks/${task}`);
        if (!response.ok) {
          throw new Error(`Request failed with ${response.status}`);
        }
        const data = await response.json();
        if (metaEl) {
          metaEl.textContent = `${data.task.filename} | marker_complete: ${data.task.marker_complete}`;
        }
        if (sourceEl) {
          sourceEl.textContent = data.source || "No source returned.";
        }
      } catch (error) {
        if (sourceEl) {
          sourceEl.textContent = `Failed to fetch source: ${error.message}`;
        }
      }
    }

    async function checkStatus() {
      if (!outputEl) return;
      outputEl.textContent = "Checking status...";
      try {
        const response = await fetch(`${apiBase}/api/labs/${lab}/tasks/${task}/status`);
        const data = await response.json();
        outputEl.textContent = JSON.stringify(data, null, 2);
      } catch (error) {
        outputEl.textContent = `Status check failed: ${error.message}`;
      }
    }

    async function runTask() {
      if (!outputEl) return;
      outputEl.textContent = "Running task...";
      try {
        const response = await fetch(`${apiBase}/api/labs/${lab}/tasks/${task}/run`, {
          method: "POST"
        });
        const data = await response.json();
        outputEl.textContent = [
          `ok: ${data.ok}`,
          `exit_code: ${data.exit_code}`,
          `marker_complete: ${data.marker_complete}`,
          "",
          "stdout:",
          data.stdout || "",
          "",
          "stderr:",
          data.stderr || ""
        ].join("\n");
      } catch (error) {
        outputEl.textContent = `Run failed: ${error.message}`;
      }
    }

    checkBtn?.addEventListener("click", checkStatus);
    runBtn?.addEventListener("click", runTask);
    loadTaskDetails();
  </script>
</BaseLayout>
