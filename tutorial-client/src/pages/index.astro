---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="AI Agent Basics Tutorial"
  subtitle="Each lab folder becomes a page. Tasks are executed through Flask REST endpoints so learners can run and inspect each step from one interface."
>
  <section class="card">
    <p class="muted">API base: <span class="mono" id="api-base">loading...</span></p>
    <div class="grid" id="labs-grid">
      <p class="muted">Loading labs...</p>
    </div>
  </section>

  <script>
    const apiBase = (import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:5050").replace(/\/$/, "");
    const labsGrid = document.getElementById("labs-grid");
    const apiBaseEl = document.getElementById("api-base");

    if (apiBaseEl) {
      apiBaseEl.textContent = apiBase;
    }

    async function loadLabs() {
      if (!labsGrid) return;
      try {
        const response = await fetch(`${apiBase}/api/labs`);
        if (!response.ok) {
          throw new Error(`Request failed with ${response.status}`);
        }
        const labs = await response.json();
        if (!Array.isArray(labs) || labs.length === 0) {
          labsGrid.innerHTML = "<p class='muted'>No labs discovered.</p>";
          return;
        }

        labsGrid.innerHTML = labs
          .map(
            (lab) => `
              <article class='card' style='animation: rise 260ms ease both;'>
                <div class='chips'>
                  <span class='chip mono'>${lab.directory}</span>
                  <span class='chip'>${lab.task_count} tasks</span>
                </div>
                <h2 style='margin: .65rem 0 .45rem;'>${lab.title}</h2>
                <a class='link-button' href='/${lab.slug}/'>Open Lab</a>
              </article>
            `
          )
          .join("");
      } catch (error) {
        labsGrid.innerHTML = `<p class='muted'>Failed to load labs: ${error.message}</p>`;
      }
    }

    const style = document.createElement("style");
    style.textContent = `
      @keyframes rise {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }
    `;
    document.head.appendChild(style);

    loadLabs();
  </script>
</BaseLayout>
